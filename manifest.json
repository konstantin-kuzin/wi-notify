{
  "manifest_version": 3,
  "name": "WI Notify",
  "description": "Показывает work items, назначенные текущему пользователю в Azure DevOps",
  "version": "0.1.3",
  "minimum_chrome_version": "116",
  "permissions": [
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://hqrndtfs.avp.ru/*",
    "https://hqrndtfsts.avp.ru/*"
  ],
  "optional_host_permissions": [
    "https://dev.azure.com/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.mjs",
    "type": "module"
  },
  "action": {
    "default_title": "WI Notify",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/bowtie.woff", "icons/AzDevMDL2.woff"],
      "matches": []
    }
  ]
}
